        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n\n    AIRPORT ||--o{ CAN_LAND : \&quot;supports landing for\&quot;\n    AIRPLANE_TYPE ||--o{ CAN_LAND : \&quot;can land at\&quot;\n\n    AIRPLANE_TYPE ||--o{ AIRPLANE : \&quot;defines the type of\&quot;\n\n    FLIGHT ||--|{ FLIGHT_LEG : \&quot;is divided into\&quot;\n\n    AIRPORT ||--o{ FLIGHT_LEG : \&quot;is the departure airport\&quot;\n    AIRPORT ||--o{ FLIGHT_LEG : \&quot;is the arrival airport\&quot;\n\n    FLIGHT_LEG ||--o{ LEG_INSTANCE : \&quot;occurs as\&quot;\n\n    AIRPLANE ||--o{ LEG_INSTANCE : \&quot;is assigned to\&quot;\n\n    AIRPORT ||--o{ LEG_INSTANCE : \&quot;is the actual departure airport\&quot;\n    AIRPORT ||--o{ LEG_INSTANCE : \&quot;is the actual arrival airport\&quot;\n\n    FLIGHT ||--o{ FARE : \&quot;offers\&quot;\n\n    LEG_INSTANCE ||--o{ SEAT : \&quot;has reserved seats\&quot;\n\n\n    AIRPORT {\n        string airport_code PK\n        string airport_name\n        string city\n        string state\n    }\n\n\n    AIRPLANE_TYPE {\n        string type_name PK\n        string company\n        int max_seats\n    }\n\n\n    CAN_LAND {\n        string airport_code PK, FK\n        string type_name PK, FK\n    }\n\n\n    AIRPLANE {\n        int airplane_id PK\n        int total_no_of_seats\n        string type_name FK\n    }\n\n\n    FLIGHT {\n        int flight_number PK\n        string airline\n        string weekdays\n    }\n\n\n    FLIGHT_LEG {\n        int flight_number PK, FK\n        int leg_no PK\n        string departure_airport_code FK\n        time scheduled_departure_time\n        string arrival_airport_code FK\n        time scheduled_arrival_time\n    }\n\n\n    LEG_INSTANCE {\n        int flight_number PK, FK\n        int leg_no PK, FK\n        date instance_date PK\n        int no_of_available_seats\n        int airplane_id FK\n        string departure_airport_code FK\n        time departure_time\n        string arrival_airport_code FK\n        time arrival_time\n    }\n\n\n    FARE {\n        int flight_number PK, FK\n        string fare_code PK\n        decimal amount\n        string restrictions\n    }\n\n\n    SEAT {\n        int flight_number PK, FK\n        int leg_no PK, FK\n        date instance_date PK, FK\n        string seat_no PK\n        string customer_name\n        string customer_phone\n    }&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="vowFRzDm7lvp1EC0T6-c-1">
